# ─── AI provider ──────────────────────────────────────────────────────────────
# The server auto-selects a provider: if OPENAI_API_KEY is set it uses the
# OpenAI-compatible path, otherwise it uses Anthropic/Claude. Force with AI_PROVIDER.
# AI_PROVIDER=openai            # or "anthropic"

PORT=3001

# ─── Option A — Claude (default) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Option B — OpenAI-compatible (pick ONE; works with any of these) ─────────
# Just set OPENAI_API_KEY (+ base url + model) and the server uses it.

# --- Groq (FREE, fast) — get key at https://console.groq.com/keys ---
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (FREE tier) — key at https://aistudio.google.com/apikey ---
# OPENAI_API_KEY=AIza...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_MODEL=gemini-2.0-flash

# --- OpenRouter (has free models) — https://openrouter.ai/keys ---
# OPENAI_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- OpenAI (cheap, NOT free — needs billing) — platform.openai.com/api-keys ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- Local (FREE, offline) — Ollama: `ollama serve` + `ollama pull llama3.1` ---
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1
